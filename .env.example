# Copy to .env and fill values for production
# Piston API is used for code execution (no setup needed - free public API)

PORT=5000

MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Public URLs
BACKEND_URL=https://your-app.onrender.com
FRONTEND_URL=https://your-app.onrender.com

# OAuth (optional - get from Google & GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Vite frontend envs (when building separately)
# Create a frontend .env file (not committed) with these keys:
# VITE_API_BASE=https://your-app.onrender.com/api
# VITE_BACKEND_URL=https://your-app.onrender.com
# VITE_SOCKET_URL=https://your-app.onrender.com
